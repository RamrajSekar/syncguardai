  "validationRules": [
    {
      "fullName": "Opportunity.Require_Close_Date_For_Closed_Won",
      "object": "Opportunity",
      "active": true,
      "errorConditionFormula": "AND(ISPICKVAL(StageName, 'Closed Won'), ISBLANK(CloseDate))",
      "errorMessage": "Close Date is required when an opportunity is Closed Won.",
      "errorDisplayField": "CloseDate"
    },
    {
      "fullName": "Opportunity.Discount_Limit_For_Standard_User",
      "object": "Opportunity",
      "active": true,
      "errorConditionFormula": "AND(Discount_Percent__c > 20, NOT($Permission.Approve_High_Discount))",
      "errorMessage": "Discounts above 20% require approval permission.",
      "errorDisplayField": "Discount_Percent__c"
    }
  ],
  "flows": [
    {
      "fullName": "Opportunity_Update_Account_Status",
      "label": "Opportunity - Update Account Status",
      "processType": "AutoLaunchedFlow",
      "triggerType": "RecordAfterSave",
      "object": "Opportunity",
      "status": "Active",
      "entryCriteria": "AND(ISCHANGED(StageName), ISPICKVAL(StageName, 'Closed Won'))",
      "actions": [
